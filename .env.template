# ============================================================
# MATERIAL INWARD PROCESS — ENVIRONMENT CONFIGURATION
# 1. Copy this file: copy .env.template .env
# 2. Fill in every value marked with <...>
# 3. NEVER commit .env to version control
# ============================================================

# --- Flask Application ---
FLASK_SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">
FLASK_ENV=production

# --- Server ---
# Dev: SERVER_HOST=127.0.0.1 (local only)
# Prod: SERVER_HOST=0.0.0.0 (accessible on network)
SERVER_HOST=127.0.0.1
SERVER_PORT=5000

# Client production URL — whitelist this on your server firewall
# Example: ALLOWED_ORIGIN=https://materialinward.supremeind.com
ALLOWED_ORIGIN=https://REPLACE_WITH_CLIENT_PRODUCTION_URL_HERE

# --- JWT ---
JWT_SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">
JWT_ALGORITHM=HS256

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=material_inward
DB_USER=material_user
DB_PASSWORD=<your-db-password>

# --- SAP Credentials ---
SAP_LOGON_PATH=C:\Program Files\SAP\FrontEnd\SAPGUI\saplogon.exe
SAP_CONNECTION_NAME=SAP Production System
SAP_CLIENT=400
SAP_USERNAME=spl_rpa
SAP_PASSWORD=<sap-rpa-password>

# --- Outlook Email (SMTP for sending + IMAP for receiving) ---
# Both use the same spl_rpa mailbox
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
EMAIL_SENDER=spl_rpa@company.com
EMAIL_PASSWORD=<email-password>

IMAP_SERVER=outlook.office365.com
IMAP_PORT=993
IMAP_USERNAME=spl_rpa@company.com
IMAP_PASSWORD=<email-password>
IMAP_POLL_FOLDER=INBOX

# --- Notification Recipients (fill when available) ---
GATEIN_OWNER_EMAIL=
MIGO_OWNER_EMAIL=
MIRO_OWNER_EMAIL=

# --- WatsonX AI (OCR) ---
WATSONX_API_KEY=<your-watsonx-api-key>
WATSONX_PROJECT_ID=<your-project-id>
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=meta-llama/llama-4-maverick-17b-128e-instruct-fp8

# --- Robot Framework ---
RF_SCRIPTS_PATH=C:\material_inward\robot_scripts
RF_OUTPUT_PATH=C:\material_inward\logs\rf_output

# --- File Upload ---
UPLOAD_FOLDER=uploads
DMS_STAGING_FOLDER=C:\material_inward\dms_staging
MAX_FILE_SIZE_MB=50

# --- Contentverse DMS Portal (dms_upload.robot) ---
CV_USERNAME=<contentverse-login-username>
CV_PASSWORD=<contentverse-login-password>

# --- Document Attachment Name Keywords ---
# Edit these if the plant team changes their file naming convention
INVOICE_KEYWORD=invoice
EWAYBILL_KEYWORD=eway
LR_KEYWORD=lr

# --- Phase Rollout: Enabled Workflow Tabs ---
# Phase 1 (Gate In only): ENABLED_STEPS=gate_in
# Phase 2 (Gate In + MIGO): ENABLED_STEPS=gate_in,migo
# All phases: ENABLED_STEPS=gate_in,migo,miro,gst
ENABLED_STEPS=gate_in,migo,miro,gst


